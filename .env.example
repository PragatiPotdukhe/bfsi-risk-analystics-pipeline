RBI_API_KEY=your_rbi_key_here
DATAGOV_API_KEY=your_datagov_key_here
GCP_PROJECT_ID=pragati-risk-analytics
GCP_DATASET=bfsi_warehouse

# Application Default Credentials path (NOT a service-account key - the GCP
# org here blocks service-account-key creation). Generate locally with:
#   gcloud auth application-default login
# then point this at the resulting file, e.g.
#   C:\Users\<you>\AppData\Roaming\gcloud\application_default_credentials.json
GOOGLE_APPLICATION_CREDENTIALS=

# Set to true to run the full pipeline against the synthetic sample CSVs in
# data/raw/ instead of the live RBI DBIE / data.gov.in APIs (both have hard
# external blockers - see SAMPLE_DATA_README.md). Real government data was
# never substituted; this is purely a dev/demo toggle.
USE_SAMPLE_DATA=true
